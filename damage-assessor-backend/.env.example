# Copy this file to .env and fill in real values. Never commit .env itself.

PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=damage_assessor

# Firebase Admin SDK — paste the full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Backend JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=30d

# Chargily Pay
CHARGILY_SECRET_KEY=
PAYMENT_SUCCESS_URL=
PAYMENT_FAILURE_URL=
PAYMENT_WEBHOOK_URL=

# AI analysis — FastAPI microservice (CarCheck), runs separately,
# typically on its own host/port. Its own .env (GROQ_API_KEY etc.)
# is managed independently of this backend.
FASTAPI_BASE_URL=http://localhost:8000
